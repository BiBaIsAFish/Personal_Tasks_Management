{
  "database_name": "Database for Task List",
  "data_source": "Database for Task List",
  "properties": {
    "Sub-item": {
      "type": "relation",
      "set_on_create": false
    },
    "完成": {
      "type": "button",
      "set_on_create": false
    },
    "類別": {
      "type": "select",
      "set_on_create": true,
      "options": ["作業", "報告", "meeting", "考試", "專案", "閱讀", "個人", "工作", "生活", "社交", "test"]
    },
    "狀態": {
      "type": "status",
      "set_on_create": true,
      "options": ["尚未開始", "進行中", "已完成"]
    },
    "Last edited time": {
      "type": "last_edited_time",
      "set_on_create": false
    },
    "優先程度": {
      "type": "select",
      "set_on_create": true,
      "options": ["不重要不緊急 Low", "不重要緊急 Medium", "重要不緊急 High", "重要緊急 Critical"]
    },
    "Parent item": {
      "type": "relation",
      "set_on_create": false
    },
    "備註": {
      "type": "rich_text",
      "set_on_create": true
    },
    "開始日": {
      "type": "date",
      "set_on_create": true
    },
    "截止日": {
      "type": "date",
      "set_on_create": true
    },
    "待辦事項": {
      "type": "title",
      "set_on_create": true,
      "required": true
    }
  },
  "create_payload_mapping": {
    "title": "待辦事項",
    "start_time": "開始日",
    "end_time": "截止日",
    "category": "類別",
    "status": "狀態",
    "priority": "優先程度",
    "notes": "備註"
  },
  "notes": [
    "button, relation, and last_edited_time properties are not set by the create helper.",
    "Integration test only sets title, date, and notes by default to avoid unknown select/status option failures."
  ]
}
